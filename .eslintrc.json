{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["react", "react-hooks"],
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/no-danger": "warn"
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "src-tauri/",
    "packages/",
    "src/core/canvas/tools/StickyNoteTool.jsx",
    "src/core/templates/integration-example.js"
  ]
}
